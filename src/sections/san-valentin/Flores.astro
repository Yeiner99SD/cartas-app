<section class="flex flex-col items-center justify-center text-center py-20 px-4 w-full">

  <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold text-white mb-8 max-w-3xl mx-auto">
    Mi amor feliz San Valentín, aquí tienes algo especial que en persona te daré
  </h1>

  <button 
    id="botonFlores"
    class="bg-rose-100 text-white px-6 py-3 rounded-xl shadow-lg transition-all duration-300 hover:scale-105 mx-auto"
  >
    Presiona aquí 
  </button>

  <!-- Imagen oculta -->
  <div class="w-full flex justify-center mt-10">
    <img 
      id="imagenFlores"
      src="/floresvalentin.webp"
      alt="Flores para ti"
      class="w-full max-w-sm sm:max-w-md md:max-w-2xl rounded-2xl shadow-2xl opacity-0 scale-90 transition-all duration-700"
    />
  </div>

</section>

<script>
  const boton = document.getElementById("botonFlores");
  const imagen = document.getElementById("imagenFlores");

  boton?.addEventListener("click", () => {
    imagen?.classList.remove("opacity-0", "scale-90");
    imagen?.classList.add("opacity-100", "scale-100");
  });
</script>
