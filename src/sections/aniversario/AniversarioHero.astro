---
---

<div class="aniversario-hero">
  <div class="stars"></div>
  
  <div class="music-card">
    <div class="card-header">
      <p class="para-siempre">· PARA SIEMPRE ·</p>
    </div>

    <div class="heart-decoration">♥</div>

    <div class="names">
      <h1>Dania</h1>
      <p class="ampersand">&</p>
      <h1>Yeiner</h1>
    </div>

    <div class="anniversary-info">
      <p class="anniversary-label">NUESTRO ANIVERSARIO</p>
      <p class="date">14 de Abril</p>
      <p class="subtitle">desde que empezamos a hablar</p>
      <p class="quote">"Quiero estar contigo para el resto de mi vida."</p>
    </div>

    <div class="player-container">
      <div class="player">
        <audio id="audioPlayer" controls>
          <source src="/audio/Gongoli (2012).mp3" type="audio/mpeg" />
          Tu navegador no soporta el elemento de audio.
        </audio>
      </div>
    </div>

    <div class="text-container">
      <p class="lyrics">
        Lee la cartita mientras escuchas la canción que siempre te dedicaré
        <span class="te-amo">Te amo</span>
      </p>
    </div>
  </div>

  <style>
    .aniversario-hero {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      overflow: hidden;
      padding: 2rem;
      font-family: "Georgia", serif;
    }

    .stars {
      position: absolute;
      width: 100%;
      height: 100%;
      top: 0;
      left: 0;
      pointer-events: none;
    }

    .stars::before,
    .stars::after {
      content: "";
      position: absolute;
      width: 2px;
      height: 2px;
      background: rgba(255, 255, 255, 0.8);
      border-radius: 50%;
      box-shadow:
        50px 50px rgba(255, 255, 255, 0.8),
        100px 100px rgba(255, 255, 255, 0.6),
        150px 200px rgba(255, 255, 255, 0.7),
        300px 50px rgba(255, 255, 255, 0.8),
        400px 150px rgba(255, 255, 255, 0.6),
        500px 75px rgba(255, 255, 255, 0.7),
        20px 200px rgba(255, 255, 255, 0.8),
        600px 250px rgba(255, 255, 255, 0.6);
      animation: twinkle 3s infinite;
    }

    @keyframes twinkle {
      0%,
      100% {
        opacity: 0.3;
      }
      50% {
        opacity: 1;
      }
    }

    .music-card {
      background: rgba(255, 255, 255, 0.15);
      backdrop-filter: blur(20px);
      border: 2px solid rgba(255, 255, 255, 0.3);
      border-radius: 30px;
      padding: 3rem;
      max-width: 500px;
      width: 100%;
      text-align: center;
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
      position: relative;
      z-index: 10;
    }

    .card-header {
      margin-bottom: 2rem;
    }

    .para-siempre {
      font-size: 0.75rem;
      letter-spacing: 3px;
      color: rgba(255, 255, 255, 0.8);
      text-transform: uppercase;
      margin: 0;
      font-weight: 300;
    }

    .heart-decoration {
      font-size: 3rem;
      color: #ff69b4;
      filter: drop-shadow(0 0 10px rgba(255, 105, 180, 0.5));
      animation: float 2s ease-in-out infinite;
      margin: 1rem 0;
    }

    @keyframes float {
      0%,
      100% {
        transform: translateY(0px);
      }
      50% {
        transform: translateY(-15px);
      }
    }

    .names {
      margin: 2rem 0;
    }

    .names h1 {
      font-size: 3.5rem;
      color: rgba(255, 255, 255, 0.95);
      margin: 0.5rem 0;
      font-weight: 300;
      letter-spacing: 2px;
    }

    .ampersand {
      font-size: 1.5rem;
      color: rgba(255, 255, 255, 0.7);
      margin: 0.5rem 0;
      font-weight: 300;
    }

    .anniversary-info {
      margin: 2rem 0;
      border-top: 1px solid rgba(255, 255, 255, 0.2);
      border-bottom: 1px solid rgba(255, 255, 255, 0.2);
      padding: 1.5rem 0;
    }

    .anniversary-label {
      font-size: 0.8rem;
      letter-spacing: 2px;
      color: rgba(255, 255, 255, 0.7);
      text-transform: uppercase;
      margin: 0;
      font-weight: 300;
    }

    .date {
      font-size: 2rem;
      color: rgba(255, 255, 255, 0.95);
      margin: 0.5rem 0;
      font-weight: 300;
      letter-spacing: 1px;
    }

    .subtitle {
      font-size: 0.9rem;
      color: rgba(255, 255, 255, 0.7);
      margin: 0.5rem 0;
      font-weight: 300;
      font-style: italic;
    }

    .quote {
      font-size: 0.85rem;
      color: rgba(255, 255, 255, 0.6);
      margin: 1rem 0 0 0;
      font-weight: 300;
      font-style: italic;
    }

    .player-container {
      margin: 2rem 0;
      background: rgba(139, 75, 168, 0.3);
      padding: 1.5rem;
      border-radius: 15px;
      margin-bottom: 2rem;
    }

    .player {
      width: 100%;
    }

    audio {
      width: 100%;
      height: 45px;
      accent-color: #ff69b4;
      outline: none;
    }

    audio::-webkit-media-controls-panel {
      background: rgba(255, 255, 255, 0.1);
    }

    .text-container {
      margin-top: 2rem;
    }

    .lyrics {
      color: rgba(255, 255, 255, 0.95);
      font-size: 1.3rem;
      line-height: 1.8;
      margin: 0;
      font-weight: 300;
      letter-spacing: 0.5px;
    }

    .te-amo {
      display: block;
      font-size: 1.8rem;
      margin-top: 0.5rem;
      color: #ff69b4;
      font-weight: normal;
      text-shadow: 0 0 20px rgba(255, 105, 180, 0.5);
    }

    @media (max-width: 640px) {
      .music-card {
        padding: 2rem;
      }

      .lyrics {
        font-size: 1.1rem;
      }

      .te-amo {
        font-size: 1.5rem;
      }

      audio {
        height: 40px;
      }
    }
  </style>
</div>

